module tb_uart_tx;

reg clk = 0;
reg reset;
reg tx_start;
reg [7:0] data_in;
wire tx;
wire busy;

uart_tx uut (
    .clk(clk),
    .reset(reset),
    .data_in(data_in),
    .tx_start(tx_start),
    .tx(tx),
    .busy(busy)
);
always #5 clk = ~clk;

initial begin
    reset = 1;
    tx_start = 0;
    data_in = 8'b10101010;

    #10 reset = 0;

    #10 tx_start = 1;
    #10 tx_start = 0;

    #200 $finish;
end

endmodule
